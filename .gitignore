# Internal planning artifacts (local only -- never tracked or shipped).
# The build workflow's spec, memory, design log, per-session reports, and
# scratch files. The spec set is double-protected by .git/info/exclude.
CLAUDE.md
STEP/
STEP.*
.claude/
.claude*
docs/DECISIONS.md
# Catch-all for every working report, including the final-resolution
# roll-up generated at release time (REPORT-final-resolution.md).
REPORT-*.md
# Prompt scaffolding and scratch / WIP / backup working files.
prompt-*.md
scratch*
notes_*
todo_*
*.wip
*.bak

# Build directories
build/
build-*/
out/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CMakeUserPresets.json
CTestTestfile.cmake
Testing/
compile_commands.json
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe
*.exp
*.lib
*.pdb
*.ilk
*.idb

# vcpkg
vcpkg_installed/
.vcpkg/
.vcpkg-root

# Coverage / profiling
*.gcov
*.gcda
*.gcno
*.profraw
*.profdata
coverage/
*.info

# Generated docs
docs/html/
docs/latex/

# Fuzzer corpus (large, regenerable)
tests/fuzz/corpus/
crash-*
oom-*
leak-*
timeout-*

# Auto-generated libFuzzer corpus mutations in the seed dirs.
# Hand-authored seeds (the committed ones) have human-readable names;
# libFuzzer writes its mutations with 40-hex-char SHA-1 filenames.
tests/fuzz/seeds/*/[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]

# Binary outputs (anchored to repo root so include/abcpwn/ is not affected)
/abcpwn
/abcpwn-full
/abcpwn-debug

# Editors / OS
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# Logs / temp
*.log
*.tmp
tmp/

# Python (if any tooling)
.venv/
__pycache__/
*.pyc
